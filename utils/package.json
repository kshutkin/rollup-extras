{
    "version": "1.4.6",
    "license": "MIT",
    "name": "@rollup-extras/utils",
    "author": "Konstantin Shutkin",
    "type": "module",
    "types": "./types/index.d.ts",
    "exports": {
        ".": {
            "types": "./types/index.d.ts",
            "default": "./src/index.js"
        },
        "./mutli-config-plugin-base": {
            "types": "./types/index.d.ts",
            "default": "./src/mutli-config-plugin-base.js"
        },
        "./options": {
            "types": "./types/index.d.ts",
            "default": "./src/options.js"
        },
        "./logger": {
            "types": "./types/index.d.ts",
            "default": "./src/logger.js"
        },
        "./statistics": {
            "types": "./types/index.d.ts",
            "default": "./src/statistics.js"
        },
        "./package.json": "./package.json"
    },
    "main": "./src/index.js",
    "module": "./src/index.js",
    "files": [
        "src",
        "types"
    ],
    "engines": {
        "node": ">=15"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/kshutkin/rollup-extras.git",
        "directory": "utils"
    },
    "bugs": "https://github.com/kshutkin/rollup-extras/issues",
    "homepage": "https://github.com/kshutkin/rollup-extras/blob/main/utils/README.md",
    "readme": "README.md",
    "description": "Utils to support creation of rollup plugins.",
    "keywords": [
        "@rollup-extras",
        "utils",
        "options",
        "multiple outputs"
    ],
    "scripts": {
        "build": "dts-buddy",
        "prepack": "pkgprn-internal --flatten types,src --strip-comments",
        "test": "vitest run --coverage --config ../vitest.config.js",
        "test:types": "tsc -p tsconfig.types.json"
    },
    "dependencies": {
        "@niceties/logger": "^2.1.0"
    },
    "peerDependencies": {
        "rollup": "^2.60.1 || ^3.0.0 || ^4.0.0"
    },
    "peerDependenciesMeta": {
        "rollup": {
            "optional": true
        }
    }
}
